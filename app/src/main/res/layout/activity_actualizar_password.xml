<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ActualizarPasswordActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/gris_oscuro"
        app:titleTextColor="@color/white"
        app:navigationIconTint="@color/white" />

    <TextView
        android:id="@+id/txtActualizarPass"
        android:layout_below="@+id/toolbar"
        android:text="@string/txtActualizarPass"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
        
    <RelativeLayout
        android:layout_below="@+id/txtActualizarPass"
        android:padding="10dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/txtInstruccionesP"
            android:text="@string/txtInstruccionesP"
            android:textAlignment="center"
            android:layout_marginTop="10dp"
            android:textSize="15sp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/TILPasswordActual"
            android:layout_below="@+id/txtInstruccionesP"
            android:layout_marginTop="10dp"
            app:passwordToggleEnabled="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <EditText
                android:id="@+id/etPasswordActual"
                android:hint="@string/etPasswordActual"
                android:inputType="textPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>


        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/TILPasswordNueva"
            android:layout_below="@+id/TILPasswordActual"
            android:layout_marginTop="10dp"
            app:passwordToggleEnabled="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <EditText
                android:id="@+id/etPasswordNueva"
                android:hint="@string/etPasswordNueva"
                android:inputType="textPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>


        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/TILPasswordNuevaR"
            android:layout_below="@+id/TILPasswordNueva"
            android:layout_marginTop="10dp"
            app:passwordToggleEnabled="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <EditText
                android:id="@+id/etPasswordNuevaR"
                android:hint="@string/etPasswordNuevaR"
                android:inputType="textPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>


        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnActualizarPassword"
            android:text="@string/btnActualizarPassword"
            app:cornerRadius="8dp"
            android:textAllCaps="true"
            android:layout_alignParentBottom="true"
            android:backgroundTint="@color/azul"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </RelativeLayout>
    

</RelativeLayout>