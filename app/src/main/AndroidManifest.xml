<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TecnoTech">
        <activity
            android:name=".Cliente.ProductosC.ProductosCatCActivity"
            android:exported="false" />
        <activity
            android:name=".SeleccionarTipoActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".Administrador.RegistroAdministradorActivity"
            android:exported="false" />
        <activity
            android:name=".Administrador.LoginAdministradorActivity"
            android:exported="false" />
        <activity
            android:name=".Administrador.MainActivityAdministrador"
            android:exported="false" />
        <activity
            android:name=".Cliente.LoginClienteActivity"
            android:exported="false" />
        <activity
            android:name=".Cliente.RegistroClienteActivity"
            android:exported="false" />
        <activity
            android:name=".Vendedor.MainActivityVendedor"
            android:exported="false" />
        <activity
            android:name=".Vendedor.RegistroVendedorActivity"
            android:exported="false" />
        <!--
Debe ir el manifest omo apertura inicial pero se pone el loggin debido a que no se ha
        implementado base de datos
        -->
        <activity
            android:name=".Vendedor.LoginVendedorActivity"
            android:exported="false" />
        <activity
            android:name=".Cliente.MainActivityCliente"
            android:exported="false" />
    </application>

</manifest>